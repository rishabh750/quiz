# Environment variables for the Spring Boot backend (all optional except in prod).
DATABASE_URL=postgresql://interviewprep:interviewprep@localhost:5432/interviewprep
CORS_ORIGINS=http://localhost:5173
STATIC_DIR=static
PORT=8000

# Secrets: if unset, APP_ENCRYPTION_KEY is generated and persisted to SECRET_DIR,
# and JWT_SECRET is derived from it. For local dev, point SECRET_DIR at a writable
# path (or set APP_ENCRYPTION_KEY) so the key is stable across restarts.
SECRET_DIR=.secrets
# APP_ENCRYPTION_KEY=
# JWT_SECRET=

# Default account seeded on startup:
# DEFAULT_USER_EMAIL=admin@interviewprep.app
# DEFAULT_USER_PASSWORD=interviewprep
# DEFAULT_USER_PROVIDER=gemini
# DEFAULT_USER_API_KEY=
