DATABASE_URL=postgresql+psycopg2://interviewprep:interviewprep@localhost:5432/interviewprep
CORS_ORIGINS=http://localhost:5173
STATIC_DIR=static

# Secrets are optional: if unset, APP_ENCRYPTION_KEY is generated and persisted to
# SECRET_DIR (default /data), and JWT_SECRET is derived from it. For local dev,
# point SECRET_DIR at a writable path (or set APP_ENCRYPTION_KEY) so the key is
# stable across restarts — otherwise a new key is generated each run and previously
# encrypted rows can't be read.
# SECRET_DIR=.secrets
# APP_ENCRYPTION_KEY=   # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# JWT_SECRET=

# Default account seeded on startup:
# DEFAULT_USER_EMAIL=admin@interviewprep.app
# DEFAULT_USER_PASSWORD=interviewprep
# DEFAULT_USER_PROVIDER=gemini
# DEFAULT_USER_API_KEY=
