# Everything here is OPTIONAL for `docker compose up`.
# The app auto-generates and persists its secrets to the /data volume on first
# run, and seeds a default login. Copy to .env only to override defaults.

# --- Secrets (auto-generated & persisted if left unset) ---
# JWT_SECRET is derived from APP_ENCRYPTION_KEY when unset.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# APP_ENCRYPTION_KEY=
# JWT_SECRET=

# --- Default account created on startup ---
# DEFAULT_USER_EMAIL=admin@interviewprep.app
# DEFAULT_USER_PASSWORD=interviewprep
# DEFAULT_USER_PROVIDER=gemini
# DEFAULT_USER_API_KEY=

# --- Database (only override for an external Postgres) ---
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
