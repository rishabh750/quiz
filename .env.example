# All optional. The app runs with zero config (in-memory store, generated secrets,
# a seeded default account admin@interviewprep.app / interviewprep).

# JWT_SECRET=<random string>       # set so sessions survive restarts / span instances
# JWT_EXPIRE_MINUTES=10080
# RSA_PRIVATE_KEY=                  # PEM; set to share the transport keypair across instances
# CORS_ORIGINS=https://your-ui.example.com   # only needed if the UI is a separate origin

# Seeded default account:
# DEFAULT_USER_EMAIL=admin@interviewprep.app
# DEFAULT_USER_PASSWORD=interviewprep
# DEFAULT_USER_PROVIDER=gemini
# DEFAULT_USER_API_KEY=
