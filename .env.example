# All optional. The app runs with zero config (in-memory H2, generated JWT secret,
# seeded default account admin@interviewprep.app / interviewprep).

# PORT=8000
# JWT_SECRET=<random string; auto-generated if unset>
# CORS_ORIGINS=https://your-ui.example.com   # only needed if UI is a separate origin

# Seeded default account:
# DEFAULT_USER_EMAIL=admin@interviewprep.app
# DEFAULT_USER_PASSWORD=interviewprep
# DEFAULT_USER_PROVIDER=gemini
# DEFAULT_USER_API_KEY=
