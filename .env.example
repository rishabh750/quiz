# The app runs with zero config locally (in-memory store; built-in stable defaults
# for the JWT secret and RSA transport keypair). There is no seeded account — create
# one via the Register screen. Override the two secrets in production.

# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
#   Persistent shared store. REQUIRED on Vercel (serverless is multi-instance);
#   Vercel's MongoDB integration injects this automatically. Unset -> in-memory.

# JWT_SECRET=<random string>       # overrides the built-in default HS256 secret
# JWT_EXPIRE_MINUTES=10080
# RSA_PRIVATE_KEY=                  # PEM; overrides the built-in transport keypair
# CORS_ORIGINS=https://your-ui.example.com   # only needed if the UI is a separate origin
