# The JWT secret has a built-in stable default (override in production). There is
# no seeded account — create one via the Register screen.

# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
#   REQUIRED — the app will not start without it (no in-memory fallback). Vercel's
#   MongoDB integration injects it automatically; set it yourself for local dev.

# JWT_SECRET=<random string>       # overrides the built-in default HS256 secret
# JWT_EXPIRE_MINUTES=10080
# CORS_ORIGINS=https://your-ui.example.com   # only needed if the UI is a separate origin
