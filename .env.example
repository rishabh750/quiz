# Credentials live in the PRIVATE `secrets` submodule, not here.
#
#   backend/secrets/dev.env         loaded when APP_ENV is unset or "dev"
#   backend/secrets/production.env  loaded when APP_ENV=production (Vercel sets
#                                   VERCEL_ENV=production automatically)
#
# Values in the selected file OVERRIDE the process environment (see backend/config.py).
# Get the submodule with:  git submodule update --init --recursive
#
# The vars below are what those files (or your shell) may set. MONGODB_URI is
# REQUIRED — the app will not start without it.

# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# JWT_SECRET=<random string>       # overrides the built-in default HS256 secret
# JWT_EXPIRE_MINUTES=10080
# CORS_ORIGINS=https://your-ui.example.com   # only needed if the UI is a separate origin
# APP_ENV=production               # force the production credential file locally
